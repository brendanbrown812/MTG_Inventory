# Copy this file to .env and fill in your values.
# docker-compose will automatically load .env from the project root.

# The URL(s) your browser uses to reach Spellbinder (comma-separated, no trailing slash).
# Must include your Cloudflare Tunnel domain once you have one.
# Example: CORS_ORIGINS=http://192.168.1.50:8888,https://spellbinder.yourdomain.com
CORS_ORIGINS=http://localhost:8888

# Host port to expose the app on (default: 8888)
PORT=8888
